      [[ -d $path ]] && print -r -- cherry-seq || print -r -- cherry
      return
    fi
    path=$(__cailoxo_git_file BISECT_LOG)
    [[ -e $path ]] && print -r -- bisect
  }

  __cailoxo_git_info() {
