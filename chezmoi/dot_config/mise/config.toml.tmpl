[tools]
# JavaScript / TypeScript runtimes and package managers
bun = "latest"
node = "lts"
pnpm = "latest"

# Language runtimes and toolchains
go = "latest"
python = "3"
rust = "latest"

# Codex tooling
codex = "latest"
"npm:oh-my-codex" = "latest"

# Shell and core terminal utilities
bat = "latest"
"aqua:eza-community/eza" = "latest"
fastfetch = "latest"
fd = "latest"
fzf = "latest"
ripgrep = "latest"
scooter = "latest"
yazi = "latest"
zoxide = "latest"

# Editors and terminal multiplexers
helix = "latest"
neovim = "latest"
"aqua:zellij-org/zellij" = "latest"

# Source control helpers
delta = "latest"
"github:jonas/tig" = { version = "latest", version_prefix = "tig-" }
lazygit = "latest"

# Security and secrets
bitwarden = "latest"

{{ if eq .chezmoi.os "windows" -}}
"github:psmux/psmux" = "latest"
"github:syncthing/syncthing" = "latest"
yt-dlp = "latest"
{{ else -}}
"aqua:tmux/tmux-builds" = "latest"
{{ end }}
