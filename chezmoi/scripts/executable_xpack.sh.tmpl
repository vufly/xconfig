#!/bin/sh

set -u

PACKAGES=$(cat <<'XPACK'
{{ includeTemplate ".chezmoitemplates/xpack-records" . -}}
XPACK
)

STATE_DIR=${XDG_STATE_HOME:-"$HOME/.local/state"}/xconfig
STATE_FILE=$STATE_DIR/packages.psv
SEP='|'
APT_UPDATED=0
APT_INVENTORY_LOADED=0
APT_INVENTORY=
DNF_INVENTORY_LOADED=0
DNF_INVENTORY=
BREW_INVENTORY_LOADED=0
BREW_FORMULA_INVENTORY=
BREW_CASK_INVENTORY=

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  STYLE_RESET=$(printf '\033[0m')
  STYLE_BOLD=$(printf '\033[1m')
  STYLE_RED=$(printf '\033[31m')
  STYLE_GREEN=$(printf '\033[32m')
  STYLE_YELLOW=$(printf '\033[33m')
  STYLE_CYAN=$(printf '\033[36m')
else
  STYLE_RESET=
  STYLE_BOLD=
  STYLE_RED=
  STYLE_GREEN=
  STYLE_YELLOW=
  STYLE_CYAN=
fi

if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
  ERROR_RESET=$(printf '\033[0m')
  ERROR_BOLD=$(printf '\033[1m')
  ERROR_RED=$(printf '\033[31m')
else
  ERROR_RESET=
  ERROR_BOLD=
  ERROR_RED=
fi

usage() {
  printf '%s%sUsage:%s xpack <command> [--yes]\n\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET"
  printf '%sCommands:%s\n' "$STYLE_BOLD" "$STYLE_RESET"
  printf '  %s%sstatus%s   Show declared package state\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET"
  printf '  %s%ssync%s     Install missing packages\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET"
  printf '  %s%supgrade%s  Upgrade manager-owned packages\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET"
  printf '  %s%sprune%s    Uninstall packages removed from declaration\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET"
  printf '  %s%sdoctor%s   Validate managers and custom scripts\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET"
}

print_error() {
  _xpack_error_format=$1
  shift
  printf '%s%s' "$ERROR_BOLD" "$ERROR_RED" >&2
  printf "$_xpack_error_format" "$@" >&2
  printf '%s' "$ERROR_RESET" >&2
}

package_key() {
  if [ "$1" = "script" ]; then
    printf 'script|%s' "$4"
  else
    printf '%s|%s|%s|%s' "$1" "$2" "$3" "$5"
  fi
}

is_desired() {
  desired_key=$(package_key "$1" "$2" "$3" "$4" "$5")
  printf '%s\n' "$PACKAGES" |
    awk -F '[|]' -v key="$desired_key" '{ target = $3 == "script" ? "script|" $8 : $3 "|" $4 "|" $5 "|" $9 } target == key { found = 1 } END { exit !found }'
}

state_contains() {
  state_path=$1
  state_key=$(package_key "$2" "$3" "$4" "$5" "$6")
  [ -f "$state_path" ] || return 1
  awk -F '[|]' -v key="$state_key" '{ target = $3 == "script" ? "script|" $8 : $3 "|" $4 "|" $5 "|" $9 } target == key { found = 1 } END { exit !found }' "$state_path"
}

run_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    print_error 'sudo is required to run %s.\n' "$1"
    return 1
  fi
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    print_error 'Required command not found: %s\n' "$1"
    return 1
  fi
}

inventory_contains() {
  _xpack_inventory=$1
  _xpack_package_id=$2
  printf '%s\n' "$_xpack_inventory" | grep -F -x "$_xpack_package_id" >/dev/null 2>&1
}

load_inventory() {
  _xpack_driver=$1
  case "$_xpack_driver" in
    apt)
      [ "$APT_INVENTORY_LOADED" -eq 1 ] && return 0
      [ "$APT_INVENTORY_LOADED" -eq -1 ] && return 2
      require_command dpkg-query || { APT_INVENTORY_LOADED=-1; return 2; }
      if ! raw_inventory=$(dpkg-query -W -f='${binary:Package}|${Status}\n' 2>/dev/null); then
        APT_INVENTORY_LOADED=-1
        return 2
      fi
      APT_INVENTORY=$(printf '%s\n' "$raw_inventory" | awk -F '[|]' '$2 == "install ok installed" { package = $1; print package; sub(/:[^:]+$/, "", package); if (package != $1) print package }')
      APT_INVENTORY_LOADED=1
      ;;
    dnf)
      [ "$DNF_INVENTORY_LOADED" -eq 1 ] && return 0
      [ "$DNF_INVENTORY_LOADED" -eq -1 ] && return 2
      require_command rpm || { DNF_INVENTORY_LOADED=-1; return 2; }
      if ! DNF_INVENTORY=$(rpm -qa --qf '%{NAME}\n%{NAME}.%{ARCH}\n%{NAME}-%{VERSION}\n%{NAME}-%{VERSION}-%{RELEASE}\n%{NAME}-%{VERSION}-%{RELEASE}.%{ARCH}\n' 2>/dev/null); then
        DNF_INVENTORY_LOADED=-1
        return 2
      fi
      DNF_INVENTORY_LOADED=1
      ;;
    brew)
      [ "$BREW_INVENTORY_LOADED" -eq 1 ] && return 0
      [ "$BREW_INVENTORY_LOADED" -eq -1 ] && return 2
      require_command brew || return 2
      if ! _xpack_raw_inventory=$(brew list --formula -1 --full-name 2>/dev/null); then
        BREW_INVENTORY_LOADED=-1
        return 2
      fi
      BREW_FORMULA_INVENTORY=$(printf '%s\n' "$_xpack_raw_inventory" | awk '{ full = $0; print full; sub(/^.*\//, "", full); if (full != $0) print full }')
      if ! _xpack_raw_inventory=$(brew list --cask -1 --full-name 2>/dev/null); then
        BREW_INVENTORY_LOADED=-1
        return 2
      fi
      BREW_CASK_INVENTORY=$(printf '%s\n' "$_xpack_raw_inventory" | awk '{ full = $0; print full; sub(/^.*\//, "", full); if (full != $0) print full }')
      BREW_INVENTORY_LOADED=1
      ;;
    *) return 2 ;;
  esac
}

add_inventory_package() {
  _xpack_driver=$1
  _xpack_id=$2
  _xpack_kind=$3
  case "$_xpack_driver" in
    apt)
      [ "$APT_INVENTORY_LOADED" -eq 1 ] || return 0
      inventory_contains "$APT_INVENTORY" "$_xpack_id" || APT_INVENTORY=$(printf '%s\n%s\n' "$APT_INVENTORY" "$_xpack_id" | sed '/^$/d')
      ;;
    dnf)
      [ "$DNF_INVENTORY_LOADED" -eq 1 ] || return 0
      inventory_contains "$DNF_INVENTORY" "$_xpack_id" || DNF_INVENTORY=$(printf '%s\n%s\n' "$DNF_INVENTORY" "$_xpack_id" | sed '/^$/d')
      ;;
    brew)
      [ "$BREW_INVENTORY_LOADED" -eq 1 ] || return 0
      if [ "$_xpack_kind" = "cask" ]; then
        inventory_contains "$BREW_CASK_INVENTORY" "$_xpack_id" || BREW_CASK_INVENTORY=$(printf '%s\n%s\n' "$BREW_CASK_INVENTORY" "$_xpack_id" | sed '/^$/d')
      else
        inventory_contains "$BREW_FORMULA_INVENTORY" "$_xpack_id" || BREW_FORMULA_INVENTORY=$(printf '%s\n%s\n' "$BREW_FORMULA_INVENTORY" "$_xpack_id" | sed '/^$/d')
      fi
      ;;
  esac
}

remove_inventory_package() {
  _xpack_driver=$1
  _xpack_id=$2
  _xpack_kind=$3
  case "$_xpack_driver" in
    apt)
      [ "$APT_INVENTORY_LOADED" -eq 1 ] && APT_INVENTORY=$(printf '%s\n' "$APT_INVENTORY" | awk -v id="$_xpack_id" '$0 != id')
      ;;
    dnf)
      [ "$DNF_INVENTORY_LOADED" -eq 1 ] && DNF_INVENTORY=$(printf '%s\n' "$DNF_INVENTORY" | awk -v id="$_xpack_id" '$0 != id')
      ;;
    brew)
      if [ "$_xpack_kind" = "cask" ]; then
        if [ "$BREW_INVENTORY_LOADED" -eq 1 ]; then
          BREW_CASK_INVENTORY=$(printf '%s\n' "$BREW_CASK_INVENTORY" | awk -v id="$_xpack_id" '$0 != id')
        fi
      else
        if [ "$BREW_INVENTORY_LOADED" -eq 1 ]; then
          BREW_FORMULA_INVENTORY=$(printf '%s\n' "$BREW_FORMULA_INVENTORY" | awk -v id="$_xpack_id" '$0 != id')
        fi
      fi
      ;;
  esac
}

script_path() {
  printf '%s/scripts/%s' "$HOME" "$1"
}

run_prepare() {
  prepare=$1
  [ -z "$prepare" ] && return 0

  path=$(script_path "$prepare")
  if [ ! -x "$path" ]; then
    print_error 'Prepare script is missing or not executable: %s\n' "$path"
    return 1
  fi
  "$path"
}

run_script_driver() {
  script=$1
  action=$2
  path=$(script_path "$script")
  if [ ! -x "$path" ]; then
    print_error 'Package script is missing or not executable: %s\n' "$path"
    return 1
  fi
  "$path" "$action"
}

check_package() {
  driver=$1
  id=$2
  kind=$3
  script=$4

  case "$driver" in
    apt)
      load_inventory apt || return 2
      inventory_contains "$APT_INVENTORY" "$id"
      [ $? -eq 0 ] && return 0 || return 10
      ;;
    dnf)
      load_inventory dnf || return 2
      inventory_contains "$DNF_INVENTORY" "$id"
      [ $? -eq 0 ] && return 0 || return 10
      ;;
    brew)
      load_inventory brew || return 2
      if [ "$kind" = "cask" ]; then
        inventory_contains "$BREW_CASK_INVENTORY" "$id"
      else
        inventory_contains "$BREW_FORMULA_INVENTORY" "$id"
      fi
      [ $? -eq 0 ] && return 0 || return 10
      ;;
    script)
      run_script_driver "$script" check
      result=$?
      [ "$result" -eq 0 ] && return 0
      [ "$result" -eq 10 ] && return 10
      return "$result"
      ;;
    *)
      print_error 'Backend driver %s is unsupported on this platform.\n' "$driver"
      return 2
      ;;
  esac
}

refresh_apt() {
  if [ "$APT_UPDATED" -eq 0 ]; then
    run_root apt-get update || return 1
    APT_UPDATED=1
  fi
}

install_package() {
  name=$1
  driver=$2
  id=$3
  kind=$4
  prepare=$5
  script=$6

  printf '%s%sInstalling%s %s through %s...\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET" "$name" "$driver"
  run_prepare "$prepare" || return 1

  case "$driver" in
    apt)
      require_command apt-get || return 1
      refresh_apt && run_root apt-get install -y "$id"
      ;;
    dnf)
      require_command dnf || return 1
      run_root dnf install -y "$id"
      ;;
    brew)
      require_command brew || return 1
      if [ "$kind" = "cask" ]; then brew install --cask "$id"; else brew install "$id"; fi
      ;;
    script) run_script_driver "$script" install ;;
    *) return 1 ;;
  esac
  result=$?
  [ "$result" -eq 0 ] && add_inventory_package "$driver" "$id" "$kind"
  return "$result"
}

upgrade_package() {
  name=$1
  driver=$2
  id=$3
  kind=$4
  prepare=$5
  script=$6

  printf '%s%sUpgrading%s %s through %s...\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET" "$name" "$driver"
  run_prepare "$prepare" || return 1

  case "$driver" in
    apt)
      require_command apt-get || return 1
      refresh_apt && run_root apt-get install --only-upgrade -y "$id"
      ;;
    dnf)
      require_command dnf || return 1
      run_root dnf upgrade -y "$id"
      ;;
    brew)
      require_command brew || return 1
      if [ "$kind" = "cask" ]; then brew upgrade --cask "$id"; else brew upgrade "$id"; fi
      ;;
    script) run_script_driver "$script" upgrade ;;
    *) return 1 ;;
  esac
}

uninstall_package() {
  name=$1
  driver=$2
  id=$3
  kind=$4
  script=$5

  printf '%s%sUninstalling%s %s through %s...\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET" "$name" "$driver"
  case "$driver" in
    apt) run_root apt-get remove -y "$id" ;;
    dnf) run_root dnf remove -y "$id" ;;
    brew)
      if [ "$kind" = "cask" ]; then brew uninstall --cask "$id"; else brew uninstall "$id"; fi
      ;;
    script) run_script_driver "$script" uninstall ;;
    *) return 1 ;;
  esac
  result=$?
  [ "$result" -eq 0 ] && remove_inventory_package "$driver" "$id" "$kind"
  return "$result"
}

save_sync_state() {
  installed_file=$1
  mkdir -p "$STATE_DIR" || return 1
  temp_state=$(mktemp "$STATE_DIR/packages.XXXXXX") || return 1

  if [ -f "$STATE_FILE" ]; then
    while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
      [ -z "$name" ] && continue
      printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$name" "$backend" "$driver" "$id" "$kind" "$updates" "$prepare" "$script" "$scope" >>"$temp_state" || {
          rm -f "$temp_state"
          return 1
        }
    done <"$STATE_FILE"
  fi

  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    [ -z "$name" ] && continue
    if ! state_contains "$temp_state" "$driver" "$id" "$kind" "$script" "$scope"; then
      printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$name" "$backend" "$driver" "$id" "$kind" "$updates" "$prepare" "$script" "$scope" >>"$temp_state" || {
          rm -f "$temp_state"
          return 1
        }
    fi
  done <"$installed_file"

  chmod 600 "$temp_state" || { rm -f "$temp_state"; return 1; }
  mv "$temp_state" "$STATE_FILE" || { rm -f "$temp_state"; return 1; }
}

status_packages() {
  failures=0
  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    [ -z "$name" ] && continue
    check_package "$driver" "$id" "$kind" "$script"
    result=$?
    case "$result" in
      0) printf '%s%s%-7s%s  %-20s %s:%s\n' "$STYLE_BOLD" "$STYLE_GREEN" present "$STYLE_RESET" "$name" "$backend" "$id" ;;
      10) printf '%s%s%-7s%s  %-20s %s:%s\n' "$STYLE_BOLD" "$STYLE_YELLOW" missing "$STYLE_RESET" "$name" "$backend" "$id"; failures=1 ;;
      *) printf '%s%s%-7s%s  %-20s %s:%s\n' "$STYLE_BOLD" "$STYLE_RED" error "$STYLE_RESET" "$name" "$backend" "$id"; failures=1 ;;
    esac
  done <<EOF
$PACKAGES
EOF
  return "$failures"
}

sync_packages() {
  failures=0
  installed_file=$(mktemp) || return 1
  trap 'rm -f "$installed_file"' EXIT HUP INT TERM
  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    [ -z "$name" ] && continue
    check_package "$driver" "$id" "$kind" "$script"
    result=$?
    if [ "$result" -eq 0 ]; then
      printf '%s%sAlready present:%s %s\n' "$STYLE_BOLD" "$STYLE_GREEN" "$STYLE_RESET" "$name"
    elif [ "$result" -eq 10 ]; then
      if install_package "$name" "$driver" "$id" "$kind" "$prepare" "$script"; then
        if ! printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
          "$name" "$backend" "$driver" "$id" "$kind" "$updates" "$prepare" "$script" "$scope" >>"$installed_file"; then
          print_error 'Installed %s, but could not record ownership.\n' "$name"
          failures=1
          break
        fi
      else
        failures=1
      fi
    else
      failures=1
    fi
  done <<EOF
$PACKAGES
EOF

  if [ -s "$installed_file" ] && ! save_sync_state "$installed_file"; then
    print_error 'Packages were installed, but ownership state could not be saved.\n'
    failures=1
  fi
  rm -f "$installed_file"
  trap - EXIT HUP INT TERM
  return "$failures"
}

upgrade_packages() {
  failures=0
  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    [ -z "$name" ] && continue
    if [ "$updates" != "manager" ]; then
      printf '%s%sSkipping%s %s updates (%s).\n' "$STYLE_BOLD" "$STYLE_YELLOW" "$STYLE_RESET" "$name" "$updates"
      continue
    fi

    check_package "$driver" "$id" "$kind" "$script"
    result=$?
    if [ "$result" -eq 0 ]; then
      upgrade_package "$name" "$driver" "$id" "$kind" "$prepare" "$script" || failures=1
    elif [ "$result" -eq 10 ]; then
      print_error 'Missing %s; run xpack sync first.\n' "$name"
      failures=1
    else
      failures=1
    fi
  done <<EOF
$PACKAGES
EOF
  return "$failures"
}

prune_packages() {
  assume_yes=$1
  if [ ! -f "$STATE_FILE" ]; then
    printf '%s%sNo package state exists; run xpack sync first.%s\n' "$STYLE_BOLD" "$STYLE_CYAN" "$STYLE_RESET"
    return 0
  fi

  mkdir -p "$STATE_DIR" || return 1
  candidates=$(mktemp) || return 1
  next_state=$(mktemp "$STATE_DIR/packages.XXXXXX") || { rm -f "$candidates"; return 1; }
  trap 'rm -f "$candidates" "$next_state"' EXIT HUP INT TERM
  state_write_failed=0

  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    [ -z "$name" ] && continue
    if ! is_desired "$driver" "$id" "$kind" "$script" "$scope"; then
      printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$name" "$backend" "$driver" "$id" "$kind" "$updates" "$prepare" "$script" "$scope" >>"$candidates" || {
          state_write_failed=1
          break
        }
    fi
  done <"$STATE_FILE"

  if [ "$state_write_failed" -eq 1 ]; then
    print_error 'Could not prepare package prune state.\n'
    return 1
  fi

  if [ ! -s "$candidates" ]; then
    printf '%s%sNothing to prune.%s\n' "$STYLE_BOLD" "$STYLE_GREEN" "$STYLE_RESET"
    return 0
  fi

  printf '%s%sPackages marked for removal:%s\n' "$STYLE_BOLD" "$STYLE_YELLOW" "$STYLE_RESET"
  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    printf '  %s (%s:%s)\n' "$name" "$backend" "$id"
  done <"$candidates"

  if [ "$assume_yes" -ne 1 ]; then
    printf '%s%sContinue? [y/N]%s ' "$STYLE_BOLD" "$STYLE_YELLOW" "$STYLE_RESET"
    read -r answer
    case "$answer" in y|Y|yes|YES) ;; *) printf '%s%sCancelled.%s\n' "$STYLE_BOLD" "$STYLE_YELLOW" "$STYLE_RESET"; return 0 ;; esac
  fi

  failures=0
  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    [ -z "$name" ] && continue
    if is_desired "$driver" "$id" "$kind" "$script" "$scope"; then
      printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$name" "$backend" "$driver" "$id" "$kind" "$updates" "$prepare" "$script" "$scope" >>"$next_state" || {
          state_write_failed=1
          break
        }
    elif ! uninstall_package "$name" "$driver" "$id" "$kind" "$script"; then
      failures=1
      printf '%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$name" "$backend" "$driver" "$id" "$kind" "$updates" "$prepare" "$script" "$scope" >>"$next_state" || {
          state_write_failed=1
          break
        }
    fi
  done <"$STATE_FILE"

  state_saved=0
  if [ "$state_write_failed" -eq 0 ] && chmod 600 "$next_state" && mv "$next_state" "$STATE_FILE"; then
    state_saved=1
  else
    print_error 'Package removals completed, but ownership state could not be saved.\n'
    failures=1
  fi
  rm -f "$candidates"
  if [ "$state_saved" -eq 1 ]; then
    trap - EXIT HUP INT TERM
  fi
  return "$failures"
}

doctor_packages() {
  failures=0
  while IFS="$SEP" read -r name backend driver id kind updates prepare script scope; do
    [ -z "$name" ] && continue
    case "$driver" in
      apt) command -v apt-get >/dev/null 2>&1 || { print_error '%s requires apt-get.\n' "$name"; failures=1; } ;;
      dnf) command -v dnf >/dev/null 2>&1 || { print_error '%s requires dnf.\n' "$name"; failures=1; } ;;
      brew) command -v brew >/dev/null 2>&1 || { print_error '%s requires brew.\n' "$name"; failures=1; } ;;
      script) [ -n "$script" ] || { print_error '%s has no package script.\n' "$name"; failures=1; } ;;
      *) print_error '%s uses unsupported driver %s.\n' "$name" "$driver"; failures=1 ;;
    esac
    if [ -n "$prepare" ] && [ ! -x "$(script_path "$prepare")" ]; then
      print_error '%s prepare script is missing: %s\n' "$name" "$prepare"
      failures=1
    fi
    if [ -n "$script" ] && [ ! -x "$(script_path "$script")" ]; then
      print_error '%s package script is missing: %s\n' "$name" "$script"
      failures=1
    fi
    case "$updates" in
      manager|self|manual) ;;
      *) print_error '%s has invalid update policy %s.\n' "$name" "$updates"; failures=1 ;;
    esac
  done <<EOF
$PACKAGES
EOF

  [ "$failures" -eq 0 ] && printf '%s%sPackage configuration is valid.%s\n' "$STYLE_BOLD" "$STYLE_GREEN" "$STYLE_RESET"
  return "$failures"
}

command=${1:-help}
assume_yes=0
[ "${2:-}" = "--yes" ] && assume_yes=1

case "$command" in
  status) status_packages ;;
  sync) sync_packages ;;
  upgrade) upgrade_packages ;;
  prune) prune_packages "$assume_yes" ;;
  doctor) doctor_packages ;;
  help|-h|--help) usage ;;
  *)
    STYLE_RESET=$ERROR_RESET
    STYLE_BOLD=$ERROR_BOLD
    STYLE_CYAN=$ERROR_RED
    usage >&2
    exit 2
    ;;
esac
