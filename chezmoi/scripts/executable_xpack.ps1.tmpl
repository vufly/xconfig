$ErrorActionPreference = "Stop"
$PSNativeCommandUseErrorActionPreference = $false

$manifest = @'
{{ includeTemplate ".chezmoitemplates/xpack-records" . -}}
'@

$packages = @(
    $manifest -split '\r?\n' |
        Where-Object { $_ } |
        ForEach-Object {
            $fields = $_ -split '\|', 9
            [PSCustomObject]@{
                Name    = $fields[0]
                Backend = $fields[1]
                Driver  = $fields[2]
                Id      = $fields[3]
                Kind    = $fields[4]
                Updates = $fields[5]
                Prepare = $fields[6]
                Script  = $fields[7]
                Scope   = $fields[8]
            }
        }
)

$stateRoot = if ($env:LOCALAPPDATA) { $env:LOCALAPPDATA } else { Join-Path $HOME ".local/state" }
$stateDir = Join-Path $stateRoot "xconfig"
$stateFile = Join-Path $stateDir "packages.json"
$wingetNoUpgrade = -1978335189
$wingetPackageNotFound = -1978335212
$packageInventories = @{}
$packageInventoryFailures = @{}
$wingetPackageStatus = [System.Collections.Generic.Dictionary[string, bool]]::new([System.StringComparer]::Ordinal)
$supportsAnsi = $PSVersionTable.PSVersion -ge [version]"7.2" -and $Host.UI.SupportsVirtualTerminal
if ($supportsAnsi) { $PSStyle.OutputRendering = "Host" }
$stdoutAnsi = $supportsAnsi -and -not $env:NO_COLOR -and -not [Console]::IsOutputRedirected
$stderrAnsi = $supportsAnsi -and -not $env:NO_COLOR -and -not [Console]::IsErrorRedirected

function Format-StyledText([string]$Text, [int]$Color, [bool]$Bold, [bool]$Enabled) {
    if (-not $Enabled) { return $Text }
    $codes = [System.Collections.Generic.List[int]]::new()
    if ($Bold) { $codes.Add(1) }
    if ($Color -gt 0) { $codes.Add($Color) }
    if ($codes.Count -eq 0) { return $Text }
    "$([char]27)[$($codes -join ';')m$Text$([char]27)[0m"
}

function Format-Output([string]$Text, [int]$Color = 0, [bool]$Bold = $false) {
    Format-StyledText $Text $Color $Bold $script:stdoutAnsi
}

function Show-Usage {
    Write-Host "$(Format-Output 'Usage:' 36 $true) xpack <command> [--yes]"
    Write-Host
    Write-Host (Format-Output "Commands:" 0 $true)
    Write-Host "  $(Format-Output 'status' 36 $true)   Show declared package state"
    Write-Host "  $(Format-Output 'sync' 36 $true)     Install missing packages"
    Write-Host "  $(Format-Output 'upgrade' 36 $true)  Upgrade manager-owned packages"
    Write-Host "  $(Format-Output 'prune' 36 $true)    Uninstall packages removed from declaration"
    Write-Host "  $(Format-Output 'doctor' 36 $true)   Validate managers and custom scripts"
}

function Write-Failure([string]$Message) {
    [Console]::Error.WriteLine((Format-StyledText $Message 31 $true $script:stderrAnsi))
}

function Get-PackageKey($Package) {
    if ($Package.Driver -eq "script") {
        return "script|$($Package.Script)"
    }
    "$($Package.Driver)|$($Package.Id)|$($Package.Kind)|$($Package.Scope)"
}

function Get-PackageKeyWithoutScope($Package) {
    "$($Package.Driver)|$($Package.Id)|$($Package.Kind)"
}

function Get-PackageDisplay($Package) {
    $display = "$($Package.Backend):$($Package.Id)"
    if ($Package.Scope) { $display += " [$($Package.Scope)]" }
    $display
}

function Get-ScriptPath([string]$RelativePath) {
    Join-Path (Join-Path $HOME "scripts") $RelativePath
}

function Invoke-NativeHostProcess([string]$FilePath, [string[]]$Arguments) {
    $startInfo = [System.Diagnostics.ProcessStartInfo]::new()
    $startInfo.FileName = $FilePath
    $startInfo.UseShellExecute = $false
    foreach ($argument in $Arguments) { [void]$startInfo.ArgumentList.Add($argument) }

    $process = [System.Diagnostics.Process]::new()
    $process.StartInfo = $startInfo
    try {
        if (-not $process.Start()) { throw "Failed to start $FilePath." }
        $process.WaitForExit()
        $process.ExitCode
    } finally {
        $process.Dispose()
    }
}

function Invoke-ScriptFile([string]$Path, [string[]]$Arguments) {
    if ([System.IO.Path]::GetExtension($Path) -eq ".ps1") {
        $hostExecutable = (Get-Process -Id $PID).Path
        & $hostExecutable -NoProfile -File $Path @Arguments | Out-Host
    } else {
        & $Path @Arguments | Out-Host
    }
    return $LASTEXITCODE
}

function Invoke-Prepare($Package) {
    if (-not $Package.Prepare) { return }
    $path = Get-ScriptPath $Package.Prepare
    if (-not (Test-Path -LiteralPath $path -PathType Leaf)) {
        throw "Prepare script is missing: $path"
    }
    $result = Invoke-ScriptFile $path @()
    if ($result -ne 0) { throw "Prepare script failed for $($Package.Name)." }
}

function Invoke-PackageScript($Package, [string]$Action) {
    $path = Get-ScriptPath $Package.Script
    if (-not $Package.Script -or -not (Test-Path -LiteralPath $path -PathType Leaf)) {
        throw "Package script is missing for $($Package.Name): $path"
    }
    Invoke-ScriptFile $path @($Action)
}

function Initialize-PackageInventory([string]$Driver) {
    if ($script:packageInventoryFailures.ContainsKey($Driver)) {
        throw $script:packageInventoryFailures[$Driver]
    }
    if ($script:packageInventories.ContainsKey($Driver)) { return }

    try {
        $comparer = if ($Driver -eq "winget") {
            [System.StringComparer]::Ordinal
        } else {
            [System.StringComparer]::OrdinalIgnoreCase
        }
        $inventory = [System.Collections.Generic.HashSet[string]]::new($comparer)
        switch ($Driver) {
            "chocolatey" {
                if (-not (Get-Command choco.exe -ErrorAction SilentlyContinue)) { throw "Chocolatey is not installed." }
                $installed = @(& choco.exe list --local-only --limit-output)
                if ($LASTEXITCODE -ne 0) { throw "Chocolatey package inventory failed." }
                foreach ($line in $installed) {
                    if ($line -match '^([^|]+)\|') { [void]$inventory.Add($Matches[1]) }
                }
            }
            "winget" {
                if (-not (Get-Command winget -ErrorAction SilentlyContinue)) { throw "winget is not installed." }
                $tempFile = Join-Path ([System.IO.Path]::GetTempPath()) ("xpack-winget-{0}.json" -f [guid]::NewGuid().ToString("N"))
                try {
                    & winget export --output $tempFile --source winget --include-versions --accept-source-agreements --disable-interactivity | Out-Null
                    if ($LASTEXITCODE -ne 0) { throw "winget package inventory failed." }
                    $document = Get-Content -LiteralPath $tempFile -Raw | ConvertFrom-Json
                    foreach ($source in @($document.Sources)) {
                        foreach ($package in @($source.Packages)) {
                            if ($package.PackageIdentifier) { [void]$inventory.Add([string]$package.PackageIdentifier) }
                        }
                    }
                } finally {
                    if (Test-Path -LiteralPath $tempFile) { Remove-Item -LiteralPath $tempFile -Force }
                }
            }
            default { throw "Backend inventory $Driver is unsupported on Windows." }
        }
        $script:packageInventories[$Driver] = $inventory
    } catch {
        $message = $_.Exception.Message
        $script:packageInventoryFailures[$Driver] = $message
        throw $message
    }
}

function Add-PackageToInventory($Package) {
    if ($Package.Driver -eq "winget" -and $Package.Scope) {
        $script:wingetPackageStatus["$($Package.Id)|$($Package.Scope)"] = $true
        return
    }
    if ($script:packageInventories.ContainsKey($Package.Driver)) {
        [void]$script:packageInventories[$Package.Driver].Add([string]$Package.Id)
    }
}

function Remove-PackageFromInventory($Package) {
    if ($Package.Driver -eq "winget" -and $Package.Scope) {
        $script:wingetPackageStatus["$($Package.Id)|$($Package.Scope)"] = $false
        return
    }
    if ($script:packageInventories.ContainsKey($Package.Driver)) {
        [void]$script:packageInventories[$Package.Driver].Remove([string]$Package.Id)
    }
}

function Get-WingetPackageStatus([string]$PackageId, [string]$Scope, [string]$Name) {
    $key = "$PackageId|$Scope"
    if ($script:wingetPackageStatus.ContainsKey($key)) { return $script:wingetPackageStatus[$key] }
    if (-not (Get-Command winget -ErrorAction SilentlyContinue)) { throw "winget is not installed." }
    & winget list --id $PackageId --exact --source winget --scope $Scope --accept-source-agreements --disable-interactivity | Out-Null
    if ($LASTEXITCODE -eq 0) {
        $script:wingetPackageStatus[$key] = $true
        return $true
    }
    if ($LASTEXITCODE -eq $wingetPackageNotFound) {
        $script:wingetPackageStatus[$key] = $false
        return $false
    }
    throw "winget query failed for $Name."
}

function Test-Package($Package) {
    switch ($Package.Driver) {
        "winget" {
            if ($Package.Scope) {
                return Get-WingetPackageStatus $Package.Id $Package.Scope $Package.Name
            }
            Initialize-PackageInventory "winget"
            return $script:packageInventories["winget"].Contains([string]$Package.Id)
        }
        "chocolatey" {
            Initialize-PackageInventory "chocolatey"
            return $script:packageInventories["chocolatey"].Contains([string]$Package.Id)
        }
        "script" {
            $result = Invoke-PackageScript $Package "check"
            if ($result -eq 0) { return $true }
            if ($result -eq 10) { return $false }
            throw "Package check failed for $($Package.Name) with exit code $result."
        }
        default { throw "Backend driver $($Package.Driver) is unsupported on Windows." }
    }
}

function Install-Package($Package) {
    Write-Host "$(Format-Output 'Installing' 36 $true) $($Package.Name) through $($Package.Driver)..."
    Invoke-Prepare $Package
    switch ($Package.Driver) {
        "winget" {
            $arguments = @("install", "--id", $Package.Id, "--exact", "--source", "winget", "--accept-source-agreements", "--accept-package-agreements", "--disable-interactivity")
            if ($Package.Scope) { $arguments += @("--scope", $Package.Scope) }
            $exitCode = Invoke-NativeHostProcess "winget" $arguments
        }
        "chocolatey" {
            $arguments = @("install", $Package.Id, "--yes")
            if ($Package.Kind -eq "prerelease") { $arguments += "--pre" }
            if ([Console]::IsOutputRedirected) { $arguments += "--no-progress" }
            $exitCode = Invoke-NativeHostProcess "choco.exe" $arguments
        }
        "script" {
            $result = Invoke-PackageScript $Package "install"
            if ($result -ne 0) { throw "Package install failed for $($Package.Name)." }
            return
        }
    }
    if ($exitCode -ne 0) { throw "Package install failed for $($Package.Name)." }
    Add-PackageToInventory $Package
}

function Upgrade-Package($Package) {
    Write-Host "$(Format-Output 'Upgrading' 36 $true) $($Package.Name) through $($Package.Driver)..."
    Invoke-Prepare $Package
    switch ($Package.Driver) {
        "winget" {
            $arguments = @("upgrade", "--id", $Package.Id, "--exact", "--source", "winget", "--accept-source-agreements", "--accept-package-agreements", "--disable-interactivity")
            if ($Package.Scope) { $arguments += @("--scope", $Package.Scope) }
            $exitCode = Invoke-NativeHostProcess "winget" $arguments
            if ($exitCode -ne 0 -and $exitCode -ne $wingetNoUpgrade) {
                throw "Package upgrade failed for $($Package.Name)."
            }
        }
        "chocolatey" {
            $arguments = @("upgrade", $Package.Id, "--yes")
            if ($Package.Kind -eq "prerelease") { $arguments += "--pre" }
            if ([Console]::IsOutputRedirected) { $arguments += "--no-progress" }
            $exitCode = Invoke-NativeHostProcess "choco.exe" $arguments
            if ($exitCode -ne 0) { throw "Package upgrade failed for $($Package.Name)." }
        }
        "script" {
            $result = Invoke-PackageScript $Package "upgrade"
            if ($result -ne 0) { throw "Package upgrade failed for $($Package.Name)." }
        }
    }
}

function Uninstall-Package($Package) {
    Write-Host "$(Format-Output 'Uninstalling' 36 $true) $($Package.Name) through $($Package.Driver)..."
    switch ($Package.Driver) {
        "winget" {
            $arguments = @("uninstall", "--id", $Package.Id, "--exact", "--source", "winget", "--disable-interactivity")
            if ($Package.Scope) { $arguments += @("--scope", $Package.Scope) }
            $exitCode = Invoke-NativeHostProcess "winget" $arguments
            if ($exitCode -ne 0) { throw "Package uninstall failed for $($Package.Name)." }
        }
        "chocolatey" {
            $arguments = @("uninstall", $Package.Id, "--yes")
            if ([Console]::IsOutputRedirected) { $arguments += "--no-progress" }
            $exitCode = Invoke-NativeHostProcess "choco.exe" $arguments
            if ($exitCode -ne 0) { throw "Package uninstall failed for $($Package.Name)." }
        }
        "script" {
            $result = Invoke-PackageScript $Package "uninstall"
            if ($result -ne 0) { throw "Package uninstall failed for $($Package.Name)." }
        }
    }
    Remove-PackageFromInventory $Package
}

function Read-State {
    if (-not (Test-Path -LiteralPath $stateFile)) { return @() }
    $content = Get-Content -LiteralPath $stateFile -Raw
    if (-not $content.Trim()) { return @() }
    @($content | ConvertFrom-Json)
}

function Write-State($Items) {
    New-Item -ItemType Directory -Path $stateDir -Force | Out-Null
    $json = ConvertTo-Json -InputObject @($Items) -Depth 4
    $tempFile = Join-Path $stateDir ("packages.{0}.tmp" -f [guid]::NewGuid().ToString("N"))
    try {
        [System.IO.File]::WriteAllText($tempFile, $json, [System.Text.UTF8Encoding]::new($false))
        Move-Item -LiteralPath $tempFile -Destination $stateFile -Force
    } finally {
        if (Test-Path -LiteralPath $tempFile) { Remove-Item -LiteralPath $tempFile -Force }
    }
}

function Resolve-OwnedPackageScope($Package) {
    if ($Package.Driver -ne "winget" -or -not $Package.Scope) { return }
    $legacyKey = Get-PackageKeyWithoutScope $Package
    $state = @(Read-State)
    $legacyPackages = @($state | Where-Object {
        $_.Driver -eq "winget" -and -not $_.Scope -and (Get-PackageKeyWithoutScope $_) -eq $legacyKey
    })
    if ($legacyPackages.Count -eq 0) { return }

    $userInstalled = Get-WingetPackageStatus $Package.Id "user" $Package.Name
    $machineInstalled = Get-WingetPackageStatus $Package.Id "machine" $Package.Name
    if ($userInstalled -and $machineInstalled) {
        throw "Cannot migrate ownership scope for $($Package.Name): both user and machine installations exist."
    }

    $resolvedScope = if ($userInstalled) { "user" } elseif ($machineInstalled) { "machine" } else { "" }
    $nextState = [System.Collections.Generic.List[object]]::new()
    foreach ($oldPackage in $state) {
        if ($oldPackage.Driver -eq "winget" -and -not $oldPackage.Scope -and (Get-PackageKeyWithoutScope $oldPackage) -eq $legacyKey) {
            continue
        }
        $nextState.Add($oldPackage)
    }
    if ($resolvedScope) {
        $resolvedPackage = $legacyPackages[0].PSObject.Copy()
        $resolvedPackage | Add-Member -MemberType NoteProperty -Name Scope -Value $resolvedScope -Force
        $resolvedKey = Get-PackageKey $resolvedPackage
        if (-not @($nextState | Where-Object { (Get-PackageKey $_) -eq $resolvedKey }).Count) {
            $nextState.Add($resolvedPackage)
        }
    }
    Write-State $nextState
}

function Save-SyncState($InstalledPackages) {
    $nextState = [System.Collections.Generic.List[object]]::new()
    $knownKeys = @{}
    foreach ($oldPackage in (Read-State)) {
        $nextState.Add($oldPackage)
        $knownKeys[(Get-PackageKey $oldPackage)] = $true
    }
    foreach ($package in $InstalledPackages) {
        $key = Get-PackageKey $package
        if (-not $knownKeys.ContainsKey($key)) {
            $nextState.Add($package)
            $knownKeys[$key] = $true
        }
    }
    Write-State $nextState
}

function Show-Status {
    $failed = $false
    foreach ($package in $packages) {
        try {
            if (Test-Package $package) {
                $label = Format-Output ("{0,-7}" -f "present") 32 $true
                Write-Host ("{0}  {1,-20} {2}" -f $label, $package.Name, (Get-PackageDisplay $package))
            } else {
                $label = Format-Output ("{0,-7}" -f "missing") 33 $true
                Write-Host ("{0}  {1,-20} {2}" -f $label, $package.Name, (Get-PackageDisplay $package))
                $failed = $true
            }
        } catch {
            $label = "{0,-7}" -f "error"
            Write-Failure ("{0}  {1,-20} {2}" -f $label, $package.Name, $_.Exception.Message)
            $failed = $true
        }
    }
    if ($failed) { return 1 }
    0
}

function Sync-Packages {
    $failed = $false
    $installedPackages = [System.Collections.Generic.List[object]]::new()
    foreach ($package in $packages) {
        try {
            Resolve-OwnedPackageScope $package
            if (Test-Package $package) {
                Write-Host "$(Format-Output 'Already present:' 32 $true) $($package.Name)"
            } else {
                Install-Package $package
                $installedPackages.Add($package)
            }
        } catch {
            Write-Failure $_.Exception.Message
            $failed = $true
        }
    }
    if ($installedPackages.Count -gt 0) { Save-SyncState $installedPackages }
    if ($failed) { return 1 }
    0
}

function Upgrade-Packages {
    $failed = $false
    foreach ($package in $packages) {
        if ($package.Updates -ne "manager") {
            Write-Host "$(Format-Output 'Skipping' 33 $true) $($package.Name) updates ($($package.Updates))."
            continue
        }
        try {
            if (Test-Package $package) {
                Upgrade-Package $package
            } else {
                Write-Failure "Missing $($package.Name); run xpack sync first."
                $failed = $true
            }
        } catch {
            Write-Failure $_.Exception.Message
            $failed = $true
        }
    }
    if ($failed) { return 1 }
    0
}

function Prune-Packages([bool]$AssumeYes) {
    try {
        foreach ($package in $packages) { Resolve-OwnedPackageScope $package }
    } catch {
        Write-Failure $_.Exception.Message
        return 1
    }
    $state = @(Read-State)
    if ($state.Count -eq 0) {
        Write-Host (Format-Output "No package state exists; run xpack sync first." 36 $true)
        return 0
    }

    $desiredKeys = @{}
    foreach ($package in $packages) { $desiredKeys[(Get-PackageKey $package)] = $true }
    $candidates = @($state | Where-Object { -not $desiredKeys.ContainsKey((Get-PackageKey $_)) })
    if ($candidates.Count -eq 0) {
        Write-Host (Format-Output "Nothing to prune." 32 $true)
        return 0
    }

    Write-Host (Format-Output "Packages marked for removal:" 33 $true)
    foreach ($package in $candidates) {
        Write-Host "  $($package.Name) ($(Get-PackageDisplay $package))"
    }

    if (-not $AssumeYes) {
        $answer = Read-Host (Format-Output "Continue? [y/N]" 33 $true)
        if ($answer -notmatch '^(?i:y|yes)$') {
            Write-Host (Format-Output "Cancelled." 33 $true)
            return 0
        }
    }

    $failed = $false
    $nextState = [System.Collections.Generic.List[object]]::new()
    foreach ($package in $state) {
        if ($desiredKeys.ContainsKey((Get-PackageKey $package))) {
            $nextState.Add($package)
            continue
        }
        try {
            Uninstall-Package $package
        } catch {
            Write-Failure $_.Exception.Message
            $nextState.Add($package)
            $failed = $true
        }
    }
    Write-State $nextState
    if ($failed) { return 1 }
    0
}

function Test-Configuration {
    $failed = $false
    foreach ($package in $packages) {
        switch ($package.Driver) {
            "winget" {
                if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
                    Write-Failure "$($package.Name) requires winget."
                    $failed = $true
                }
            }
            "chocolatey" {
                if (-not (Get-Command choco.exe -ErrorAction SilentlyContinue)) {
                    Write-Failure "$($package.Name) requires Chocolatey."
                    $failed = $true
                }
            }
            "script" {
                if (-not $package.Script -or -not (Test-Path -LiteralPath (Get-ScriptPath $package.Script))) {
                    Write-Failure "$($package.Name) package script is missing."
                    $failed = $true
                }
            }
            default {
                Write-Failure "$($package.Name) uses unsupported driver $($package.Driver)."
                $failed = $true
            }
        }
        if ($package.Prepare -and -not (Test-Path -LiteralPath (Get-ScriptPath $package.Prepare))) {
            Write-Failure "$($package.Name) prepare script is missing: $($package.Prepare)"
            $failed = $true
        }
        if ($package.Updates -notin @("manager", "self", "manual")) {
            Write-Failure "$($package.Name) has invalid update policy $($package.Updates)."
            $failed = $true
        }
        if ($package.Scope -and ($package.Driver -ne "winget" -or $package.Scope -notin @("user", "machine"))) {
            Write-Failure "$($package.Name) has invalid package scope $($package.Scope)."
            $failed = $true
        }
    }
    if (-not $failed) { Write-Host (Format-Output "Package configuration is valid." 32 $true) }
    if ($failed) { return 1 }
    0
}

$command = if ($args.Count -gt 0) { $args[0] } else { "help" }
$assumeYes = $args -contains "--yes"

$exitCode = switch ($command) {
    "status" { Show-Status }
    "sync" { Sync-Packages }
    "upgrade" { Upgrade-Packages }
    "prune" { Prune-Packages $assumeYes }
    "doctor" { Test-Configuration }
    { $_ -in @("help", "-h", "--help") } { Show-Usage; 0 }
    default { Show-Usage; 2 }
}

exit $exitCode
