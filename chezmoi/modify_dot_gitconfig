{{- /* chezmoi:modify-template */ -}}
{{- $isLight := or (contains "light = true" .chezmoi.stdin) (contains "syntax-theme = \"bearded-theme-milkshake-vanilla\"" .chezmoi.stdin) (contains "syntax-theme = bearded-theme-milkshake-vanilla" .chezmoi.stdin) (contains "syntax-theme = \"Bearded Theme Milkshake Vanilla\"" .chezmoi.stdin) (contains "syntax-theme = Bearded Theme Milkshake Vanilla" .chezmoi.stdin) -}}
{{- $deltaModeKey := ternary "light" "dark" $isLight -}}
{{- $deltaThemeName := ternary "bearded-theme-milkshake-vanilla" "bearded-theme-monokai-stone" $isLight -}}
[user]
	name = Nguyen Dinh Vu
	email = nguyendinhvu@msn.com

[includeIf "gitdir:~/o24/"]
path = ~/o24/.gitconfig
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	rebase = true
[color]
	ui = true
[push]
  autoSetupRemote = true

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true  # use n and N to move between diff sections
  line-numbers = true
  hyperlinks = true
  line-numbers-minus-style = 1
  line-numbers-zero-style = 243
  line-numbers-plus-style = 2
  # These values are updated manually by ~/scripts/set-theme.sh.
  {{ $deltaModeKey }} = true
  syntax-theme = "{{ $deltaThemeName }}"

[merge]
  conflictStyle = zdiff3
