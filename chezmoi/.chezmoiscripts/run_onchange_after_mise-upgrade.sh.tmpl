{{- if ne .chezmoi.os "windows" -}}
#!/bin/sh
# mise config hash: {{ includeTemplate "dot_config/mise/config.toml.tmpl" . | sha256sum }}

set -eu

prefix="$(printf '\033[1;34m[chezmoi]\033[0m')"
mise_word="$(printf '\033[35mmise\033[0m')"

if ! command -v mise >/dev/null 2>&1; then
  printf '%s %s config changed, but %s is not installed; skipping.\n' "$prefix" "$mise_word" "$mise_word"
  exit 0
fi

cd "$HOME"
printf '%s %s config changed; updating tools in $HOME.\n' "$prefix" "$mise_word"
printf '%s Running %s upgrade...\n' "$prefix" "$mise_word"
mise upgrade
printf '%s Running %s prune --yes...\n' "$prefix" "$mise_word"
mise prune --yes
printf '%s %s update completed.\n' "$prefix" "$mise_word"
{{- end -}}
